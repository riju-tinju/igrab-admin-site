# iGrab Admin Environment Variables Template

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DB_NAME=iGrab_DB

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=3007
BRAND_NAME=iGrab Story Cafe

# -----------------------------------------------------------------------------
# Security & Sessions
# -----------------------------------------------------------------------------
# Generate a strong random string for SESSION_SECRET (e.g., openssl rand -hex 32)
SESSION_SECRET=your_secure_admin_session_secret_here

# Environment Setting:
# 'development' -> Disables secure cookies (HTTP ok for localhost)
# 'production'  -> Enables secure cookies (HTTPS required)
NODE_ENV=development

# Cookie Security Override
# Set to 'false' if your production server is behind a proxy that doesn't forward X-Forwarded-Proto header
COOKIE_SECURE=false

# Bypass authentication locally (Useful for dev; ensure this is false in prod)
ADMIN_AUTO_LOGIN=false

# -----------------------------------------------------------------------------
# Email Configuration (Nodemailer)
# -----------------------------------------------------------------------------
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-google-app-password

# -----------------------------------------------------------------------------
# SMS / Twilio Configuration
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=your_twilio_phone

# -----------------------------------------------------------------------------
# API Keys
# -----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=your_google_maps_key

# -----------------------------------------------------------------------------
# Application Limits
# -----------------------------------------------------------------------------
PRODUCT_LIMIT=25
IMAGE_LIMIT=4
IMAGE_SIZE_LIMIT=2
# -----------------------------------------------------------------------------
# Firebase Cloud Messaging
# -----------------------------------------------------------------------------
# Path to the Firebase service account JSON file (relative to root or absolute)
FIREBASE_SERVICE_ACCOUNT_PATH=config/firebase-service-account.json
